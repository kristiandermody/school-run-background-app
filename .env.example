# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Google Maps Directions API key
# Get one at: https://console.cloud.google.com/
SCHOOL_RUN_API_KEY=your_google_maps_api_key_here

# Full address of your starting point (home)
SCHOOL_RUN_ORIGIN=123 Your Street, Your City, State ZIP

# Full address of the school (destination)
SCHOOL_RUN_DEST=456 School Ave, Your City, State ZIP
